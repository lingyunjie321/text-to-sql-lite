DEMO_DATABASE_URL=sqlite:///data/sqlite/demo.db
TEXT_TO_SQL_WORKFLOW_CONFIG=workflow.yaml

# 使用 workflow.yaml 的结构化 Postgres/MySQL 连接时，只把密码放环境变量。
TEXT_TO_SQL_DB_PASSWORD=replace-with-your-database-password

# workflow.yaml 默认 light/strong alias 使用 DeepSeek 命名的 OpenAI-compatible 配置。
# 把真实密钥写到本地 .env.local，不要提交。
DEEPSEEK_API_KEY=replace-with-your-api-key
DEEPSEEK_BASE_URL=https://your-openai-compatible-endpoint/v1/chat/completions

# 如果要把 workflow.yaml 改成 OPENAI_* 环境变量，也可以继续使用下面两个变量。
OPENAI_API_KEY=replace-with-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
